<?xml version = "1.0" encoding = "utf-8"?>
<component name = "MovieDetailsPanel" extends = "Panel" initialFocus = "PlayButton">
    <interface>
        <field id = "content" type = "node" onchange = "UpdatePoster" alwaysNotify = "true"/>
    </interface>
    <script type = "text/brightscript" uri = "MovieDetailsPanel.brs"></script>
    <children>
        <Poster
            id = "MoviePoster"
            width = "388"
            height = "218"
            translation = "[0, 44]"
        >
        </Poster>
        <Button
            id = "PlayButton"
            text = ""
            iconUri = "pkg:/images/icon_play.png"
            focusedIconUri = "pkg:/images/icon_play_focused.png"
            minWidth = "92"
            maxWidth = "92"
            translation = "[10, 268]"
        >
        </Button>
        <Label
            id = "RatingReleaseDate"
            width = "250"
            translation = "[130, 300]"
            font = "font:SmallSystemFont"
        >
        </Label>
        <Rectangle
            id = "Separator"
            width = "388"
            height = "1"
            color = "0x888888FF"
            translation = "[0, 335]"
        >
        </Rectangle>
        <Label
            id = "Description"
            translation = "[0, 350]"
            width = "388"
            wrap = "true"
            maxLines = "7"
            font = "font:SmallSystemFont"
        >
        </Label>
    </children>
</component>